@import "../../styles/warm-theme.wxss";

/* ===== Menu - Warm Calm ===== */
.menu-page {
  background: #F3F0EB;
  min-height: 100vh;
}

/* 顶部工具栏 */
.menu-top {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(243, 240, 235, 0.92);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  border-bottom: 1px solid #EDE8E2;
}

.menu-filter-btn {
  font-size: 24rpx;
  color: #8A847E;
  padding: 10rpx 20rpx;
  background: #F1DED9;
  border-radius: 999rpx;
  white-space: nowrap;
  transition: all 0.2s;
}

.menu-filter-btn:active {
  background: #C97060;
  color: #fff;
}

.menu-filter-info {
  font-size: 22rpx;
  color: #B0A8A0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 120rpx;
  flex-shrink: 0;
}

.menu-search {
  flex: 1;
  height: 56rpx;
  background: #FFFFFF;
  border-radius: 999rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.menu-search input {
  flex: 1;
  background: transparent;
  border: none;
  font-size: 24rpx;
  color: #2C2C2A;
  height: 100%;
}

.menu-search input::placeholder {
  color: #B0A8A0;
}

.menu-cart-btn {
  font-size: 40rpx;
  position: relative;
  padding: 8rpx;
  transition: transform 0.2s;
  flex-shrink: 0;
}

.menu-cart-btn:active {
  transform: scale(0.9);
}

/* 菜品列表 */
.dish-list {
  width: 100%;
  height: 100vh;
  box-sizing: border-box;
}

.dish-list-inner {
  padding: 100rpx 32rpx 32rpx;
  box-sizing: border-box;
}

/* 菜品项 */
.dish-item {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1px solid #EDE8E2;
  transition: all 0.2s;
}

.dish-item:last-child {
  border-bottom: none;
}

.dish-item:active {
  opacity: 0.7;
}

.dish-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #EDE8E2;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.dish-img image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.dish-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.dish-name-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.dish-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2C2A;
  line-height: 1.3;
}

.dish-tag {
  display: inline-block;
  padding: 2rpx 12rpx;
  background: #F1DED9;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #C97060;
  margin-top: 6rpx;
}

.dish-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.dish-stat {
  font-size: 22rpx;
  color: #B0A8A0;
}

.dish-ingredient {
  font-size: 22rpx;
  color: #B0A8A0;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-actions {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.dish-longpress-hint {
  font-size: 20rpx;
  color: #B0A8A0;
  margin-top: 4rpx;
  opacity: 0.5;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx 0;
  color: #B0A8A0;
  font-size: 24rpx;
}

/* 筛选弹窗 */
.filter-sheet {
  background: #FFFFFF !important;
  border-radius: 24rpx 24rpx 0 0 !important;
}

/* 长按操作弹窗 */
.action-dialog {
  background: #FFFFFF !important;
  border-radius: 20rpx !important;
  max-width: 480rpx !important;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06) !important;
}

.action-dialog .weui-dialog__bd {
  display: flex !important;
  justify-content: space-around !important;
  padding: 40rpx 40rpx 16rpx !important;
}

.action-btn {
  width: 88rpx !important;
  height: 88rpx !important;
  line-height: 88rpx !important;
  text-align: center !important;
  border-radius: 50% !important;
  font-size: 40rpx !important;
  background: #F1DED9 !important;
  border: none !important;
  transition: all 0.2s;
}

.action-btn:active {
  background: #C97060 !important;
  transform: scale(0.9);
}

.action-hint {
  text-align: center;
  padding: 0 0 24rpx;
  color: #B0A8A0;
  font-size: 22rpx;
}
