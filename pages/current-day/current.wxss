@import "../../styles/warm-theme.wxss";

/* ===== Current Day - Warm Calm ===== */
.current-page {
  background: #F3F0EB;
  min-height: 100vh;
  width: 100%;
  overflow: hidden;
}

.current-header {
  text-align: center;
  padding: 36rpx 0 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #2C2C2A;
}

.current-header::after {
  content: '';
  display: block;
  width: 48rpx;
  height: 4rpx;
  background: #C97060;
  border-radius: 2rpx;
  margin: 12rpx auto 0;
  opacity: 0.3;
}

.current-list {
  width: 100%;
  height: calc(100vh - 110rpx);
}

.current-list-inner {
  padding: 0 28rpx 40rpx;
  box-sizing: border-box;
}

/* ===== Dish Item Cards ===== */
.current-item {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}

.current-item:active {
  transform: scale(0.99);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.current-item:last-child {
  margin-bottom: 0;
}

/* Hover feedback for card items */
.item-hover {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  transition: all 0.15s;
}

.current-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #EDE8E2;
}

.current-img image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.current-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8rpx;
}

.current-name-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.current-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2C2A;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-top: 2rpx;
}

.current-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  background: #F1DED9;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #C97060;
  align-self: flex-start;
}

.current-desc {
  font-size: 22rpx;
  color: #B0A8A0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== Remove Button - Compact, Consistent ===== */
.current-remove-btn {
  font-size: 20rpx !important;
  padding: 6rpx 16rpx !important;
  line-height: 1.3 !important;
  border-radius: 999rpx !important;
  background: #F1DED9 !important;
  color: #C97060 !important;
  border: none !important;
  transition: all 0.2s;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* Remove WeChat default button border */
.current-remove-btn::after {
  border: none !important;
}

.current-remove-btn:active {
  background: #E5C8BE !important;
  opacity: 0.8;
  transform: scale(0.94);
}

/* ===== Section Headers ===== */
.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 40rpx 4rpx 20rpx;
}

.section-header:first-child {
  padding-top: 8rpx;
}

.section-icon {
  font-size: 34rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C2C2A;
}

.section-count {
  font-size: 20rpx;
  color: #8A847E;
  margin-left: auto;
  background: #EDE8E2;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 500;
}

/* ===== Food Kind Header (Hotpot) ===== */
.kind-header {
  padding: 8rpx 4rpx 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #C97060;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.kind-header::before {
  content: '·';
  font-size: 32rpx;
  font-weight: 700;
  color: #C97060;
  line-height: 1;
}
