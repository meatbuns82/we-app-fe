@import "../../styles/warm-theme.wxss";

/* ==========================================
   Current Day · 今日小菜 — Redesigned
   Warm Calm design system
   ========================================== */

.current-page {
  background: #F3F0EB;
  min-height: 100vh;
}

/* ===== 顶部区域 ===== */
.current-top {
  background: linear-gradient(135deg, #F3F0EB 0%, #EDE8E2 100%);
  padding: 40rpx 32rpx 32rpx;
  position: relative;
}

.current-top::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 32rpx;
  right: 32rpx;
  height: 1px;
  background: linear-gradient(90deg, transparent, #E2DBD4, transparent);
}

.current-top-inner {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.current-top-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2C2C2A;
  letter-spacing: 2rpx;
}

.current-top-date {
  font-size: 22rpx;
  color: #8A847E;
  background: rgba(255,255,255,0.6);
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
}

/* ===== 统计条 ===== */
.current-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  margin-top: 28rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #C97060;
  line-height: 1.1;
}

.stat-num-stir {
  color: #C97060;
}

.stat-num-hotpot {
  color: #A5B8A5;
}

.stat-label {
  font-size: 22rpx;
  color: #8A847E;
}

.stat-divider {
  width: 1px;
  height: 40rpx;
  background: #EDE8E2;
}

/* ===== 空状态 ===== */
.empty-section {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 160rpx 32rpx;
}

.empty-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 72rpx 64rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.04);
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 28rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2C2C2A;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #B0A8A0;
}

/* ===== 滚动区域 ===== */
.current-scroll {
  width: 100%;
  height: 100vh;
  box-sizing: border-box;
}

.current-scroll-inner {
  padding: 0 28rpx 60rpx;
  box-sizing: border-box;
}

/* ===== 分区头 ===== */
.section-wrap {
  margin-top: 8rpx;
}

.section-head {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 36rpx 4rpx 24rpx;
}

.section-head-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.section-emoji {
  font-size: 32rpx;
}

.section-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #2C2C2A;
}

.section-badge {
  font-size: 20rpx;
  color: #C97060;
  background: #F1DED9;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 500;
  margin-left: 4rpx;
}

.section-badge-hotpot {
  color: #A5B8A5;
  background: #EBF1E8;
}

.section-line {
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, #E2DBD4, transparent);
}

/* ===== 食材分组头（火锅） ===== */
.kind-group {
  margin-bottom: 8rpx;
}

.kind-group-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 6rpx 16rpx;
}

.kind-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #A5B8A5;
  flex-shrink: 0;
}

.kind-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #A5B8A5;
}

.kind-count {
  font-size: 20rpx;
  color: #B0A8A0;
  margin-left: auto;
  background: #F5F0EB;
  padding: 2rpx 14rpx;
  border-radius: 999rpx;
}

/* ===== 菜品卡片 ===== */
.section-cards {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.dish-card {
  display: flex;
  gap: 20rpx;
  padding: 22rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  transition: all 0.25s ease;
}

.dish-card-hover {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  transition: all 0.15s;
}

/* ===== 卡片图片 ===== */
.dish-card-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #EDE8E2;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.dish-card-img image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ===== 卡片内容 ===== */
.dish-card-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 12rpx;
}

.dish-card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
}

.dish-card-title-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.dish-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2C2A;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-card-tag {
  display: inline-block;
  align-self: flex-start;
  padding: 4rpx 14rpx;
  background: #F1DED9;
  border-radius: 999rpx;
  font-size: 20rpx;
  color: #C97060;
  line-height: 1.3;
}

.dish-card-desc {
  font-size: 22rpx;
  color: #B0A8A0;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 不吃了按钮 ===== */
.dish-card-remove {
  flex-shrink: 0;
  font-size: 22rpx !important;
  padding: 8rpx 20rpx !important;
  line-height: 1.2 !important;
  border-radius: 999rpx !important;
  background: #F5F0EB !important;
  color: #B0A8A0 !important;
  border: none !important;
  transition: all 0.2s;
  min-width: 0 !important;
  margin: 0 !important;
}

.dish-card-remove::after {
  border: none !important;
}

.dish-card-remove:active {
  background: #F1DED9 !important;
  color: #C97060 !important;
  transform: scale(0.92);
}

/* ===== 底部 ===== */
.current-footer {
  text-align: center;
  padding: 48rpx 0 32rpx;
}

.current-footer-text {
  font-size: 22rpx;
  color: #C9C2BA;
  letter-spacing: 4rpx;
}
